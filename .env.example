# Translation Engine — credentials
# Copy this file to .env and fill in real values. .env is gitignored.

# --- Jira Cloud ---
# Site URL (no trailing slash)
JIRA_SITE_URL=https://designisagoodidea.atlassian.net

# Email tied to your Atlassian account
JIRA_EMAIL=designisagoodidea@gmail.com

# API token from id.atlassian.com → Security → API tokens
JIRA_API_TOKEN=

# Project key (visible in issue keys, e.g. SCRUM-1 → SCRUM)
JIRA_PROJECT_KEY=SCRUM

# --- Airtable ---
# Personal Access Token from airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_TOKEN=

# Base ID of the synthetic demo base
AIRTABLE_BASE_ID=

# Table ID (not name) of the destination table
AIRTABLE_TABLE_ID=
